"""
Karaoke Application - View, Controller, and Model
A complete karaoke system with recording, lyrics display with highlighting,
and playback of mixed audio (recorded voice + backing track).
"""

import os
import tkinter as tk
from tkinter import ttk, messagebox
import threading
import time
from pathlib import Path
import numpy as np
from scipy import signal as sg
import sounddevice as sd
from _soundfile import read as sf_read, write as sf_write

# Get the absolute paths for project directories
SCRIPT_DIR = Path(__file__).parent.parent
SOUNDS_DIR = SCRIPT_DIR / "Sounds"
LYRICS_FILE = SCRIPT_DIR / "Figures" / "Assets" / "lyrics.txt"
SONG_FILE = SOUNDS_DIR / "NeverGonnaGiveYouUp.wav"


# ============================================================================
# MODEL - Handles audio data and lyrics
# ============================================================================

class KaraokeModel:
    """
    The Model handles all audio processing, file I/O, and data management.
    
    Responsibilities:
    - Load and manage song audio data
    - Load and parse lyrics
    - Calculate timing for lyrics display
    - Manage recording and playback audio
    - Save recordings to file
    """

    def __init__(self):
        """
        Initialize the KaraokeModel by loading audio and lyrics files.
        
        Raises:
            FileNotFoundError: If song or lyrics files don't exist.
            RuntimeError: If audio files can't be read.
        """
        try:
            # Load song audio
            if not SONG_FILE.exists():
                raise FileNotFoundError(f"Song file not found: {SONG_FILE}")
            
            self.data, self.fs = sf.read(str(SONG_FILE), dtype="float32")
            
            # Convert stereo to mono if needed
            if self.data.ndim > 1:
                self.data = self.data[:, 0]
            
            self.duration = len(self.data) / self.fs
            
            # Load lyrics
            if not LYRICS_FILE.exists():
                raise FileNotFoundError(f"Lyrics file not found: {LYRICS_FILE}")
            
            with open(LYRICS_FILE, "r") as f:
                self.lyrics_full = f.read()
            
            # Parse lyrics into words with timing
            self.lyrics_words = self._parse_lyrics_with_timing()
            
            # Recording data
            self.recorded_audio = None
            self.score = 0
            
        except Exception as e:
            raise RuntimeError(f"Error initializing KaraokeModel: {str(e)}")

    def _parse_lyrics_with_timing(self):
        """
        Parse lyrics into words with approximate timing information.
        
        This distributes words evenly across the song duration.
        In a real implementation, you'd have a timing map for each word.
        
        Returns:
            list: List of tuples (word, start_time, end_time)
        """
        words = self.lyrics_full.split()
        if len(words) == 0:
            return []
        
        time_per_word = self.duration / len(words)
        lyrics_with_timing = []
        
        for i, word in enumerate(words):
            start_time = i * time_per_word
            end_time = (i + 1) * time_per_word
            lyrics_with_timing.append((word, start_time, end_time))
        
        return lyrics_with_timing

    def play_audio(self):
        """
        Start playing the loaded audio track.
        Uses sounddevice for non-blocking playback.
        """
        try:
            sd.play(self.data, self.fs)
        except Exception as e:
            print(f"Error playing audio: {str(e)}")

    def stop_audio(self):
        """
        Stop all audio playback immediately.
        """
        sd.stop()

    def record_audio(self):
        """
        Record audio from the microphone for the duration of the song.
        
        Returns:
            np.ndarray: The recorded audio samples, or None if recording failed.
        """
        try:
            duration_samples = int(self.duration * self.fs)
            print(f"Recording for {self.duration:.1f} seconds...")
            
            recorded = sd.rec(duration_samples, samplerate=self.fs, channels=1)
            sd.wait()  # Wait for recording to complete
            
            self.recorded_audio = recorded.flatten()
            return self.recorded_audio
            
        except Exception as e:
            print(f"Error recording audio: {str(e)}")
            return None

    def save_recording(self):
        """
        Save the recorded audio to a WAV file.
        
        Returns:
            bool: True if successful, False otherwise.
        """
        if self.recorded_audio is None:
            print("No recorded audio to save")
            return False
        
        try:
            output_path = SOUNDS_DIR / "recorded_audio.wav"
            sf.write(str(output_path), self.recorded_audio, self.fs)
            print(f"Recording saved to {output_path}")
            return True
        except Exception as e:
            print(f"Error saving recording: {str(e)}")
            return False

    def get_mixed_audio(self, song_volume=0.5, rec_volume=0.5):
        """
        Mix the recorded audio with the original song audio.
        
        Args:
            song_volume (float): Volume level for the song (0.0 to 1.0)
            rec_volume (float): Volume level for the recording (0.0 to 1.0)
        
        Returns:
            tuple: (mixed_audio, sample_rate) or (None, None) if mixing failed
        """
        if self.recorded_audio is None:
            print("No recorded audio available for mixing")
            return None, None
        
        try:
            # Ensure both arrays have the same length
            min_len = min(len(self.data), len(self.recorded_audio))
            song_trimmed = self.data[:min_len]
            rec_trimmed = self.recorded_audio[:min_len]
            
            # Mix the audio
            mixed = (song_volume * song_trimmed + rec_volume * rec_trimmed) / 2.0
            
            # Normalize to prevent clipping
            max_val = np.max(np.abs(mixed))
            if max_val > 1.0:
                mixed = mixed / max_val
            
            return mixed, self.fs
            
        except Exception as e:
            print(f"Error mixing audio: {str(e)}")
            return None, None

    def load_lyrics(self):
        """
        Get the full lyrics text.
        
        Returns:
            str: The complete lyrics text.
        """
        return self.lyrics_full

    def calculate_score(self):
        """
        Calculate a score based on the recording (placeholder implementation).
        
        In a real implementation, this would compare pitch, timing, and volume
        of the recorded voice with the original song using the YIN algorithm.
        
        Returns:
            int: A score from 0 to 100.
        """
        # Placeholder: return a score based on recording volume level
        if self.recorded_audio is None:
            return 0
        
        # Simple volume-based scoring
        volume_level = np.max(np.abs(self.recorded_audio))
        score = int(min(100, volume_level * 200))  # Scale to 0-100
        
        return max(0, score)


# ============================================================================
# CONTROLLER - Manages interaction between View and Model
# ============================================================================

class KaraokeController:
    """
    The Controller manages the interaction between the View and Model.
    
    Responsibilities:
    - Handle user input from the View
    - Coordinate recording and playback
    - Update View with model data
    - Manage threading for audio operations
    - Manage lyrics display with timing
    """

    def __init__(self, model, view):
        """
        Initialize the controller with references to Model and View.
        
        Args:
            model (KaraokeModel): The data/logic layer
            view (KaraokeView): The UI layer
        """
        self.model = model
        self.view = view
        self.recording = False
        self.playback_thread = None
        self.recording_thread = None
        
        # Display initial lyrics
        self.view.update_lyrics(self.model.load_lyrics())
        self.view.controller = self

    def toggle_recording(self):
        """
        Start or stop recording based on current state.
        
        When starting: Begins playback and recording simultaneously in separate threads.
        When stopping: Stops all audio, saves recording, and plays mixed result.
        """
        if not self.recording:
            # Start recording
            self.recording = True
            self.view.record_btn.config(state=tk.DISABLED)
            self.view.status_label.config(text="Recording in progress...")
            
            # Start playback and recording in separate threads
            self.playback_thread = threading.Thread(target=self._playback_with_lyrics)
            self.recording_thread = threading.Thread(target=self._record_and_mix)
            
            self.playback_thread.daemon = True
            self.recording_thread.daemon = True
            
            self.playback_thread.start()
            self.recording_thread.start()
        else:
            # Stop recording
            self.recording = False
            self.model.stop_audio()
            sd.stop()
            
            # Wait briefly for threads to finish
            if self.recording_thread:
                self.recording_thread.join(timeout=2)
            if self.playback_thread:
                self.playback_thread.join(timeout=2)
            
            self.view.status_label.config(text="Processing recording...")
            self.view.update()
            
            # Save and play mixed audio
            self.model.save_recording()
            mixed_audio, fs = self.model.get_mixed_audio(song_volume=0.4, rec_volume=0.6)
            
            if mixed_audio is not None:
                self._play_mixed_audio(mixed_audio, fs)
                score = self.model.calculate_score()
                self.view.update_score(score)
            
            self.view.status_label.config(text="Ready to record")
            self.view.record_btn.config(state=tk.NORMAL)

    def _playback_with_lyrics(self):
        """
        Play the song and update lyrics display in real-time.
        
        This runs in a separate thread to avoid blocking the UI.
        It updates which word should be highlighted based on playback time.
        """
        try:
            self.model.play_audio()
            start_time = time.time()
            
            while self.recording:
                elapsed = time.time() - start_time
                
                # Find current word
                current_word_idx = None
                for i, (word, start_t, end_t) in enumerate(self.model.lyrics_words):
                    if start_t <= elapsed <= end_t:
                        current_word_idx = i
                        break
                
                # Update display
                if current_word_idx is not None:
                    self.view.update_lyrics_with_highlight(
                        self.model.lyrics_words,
                        current_word_idx
                    )
                
                time.sleep(0.05)  # Update display 20 times per second
                
        except Exception as e:
            print(f"Error in playback: {str(e)}")

    def _record_and_mix(self):
        """
        Record audio from the microphone while the song is playing.
        
        This runs in a separate thread to avoid blocking the UI.
        """
        try:
            self.model.record_audio()
        except Exception as e:
            print(f"Error in recording: {str(e)}")

    def _play_mixed_audio(self, mixed_audio, fs):
        """
        Play the mixed audio (recorded voice + backing track).
        
        Args:
            mixed_audio (np.ndarray): The mixed audio samples
            fs (int): Sample rate of the audio
        """
        try:
            print("Playing mixed audio (recorded voice + backing track)...")
            sd.play(mixed_audio, fs)
            sd.wait()
            print("Playback complete")
        except Exception as e:
            print(f"Error playing mixed audio: {str(e)}")


# ============================================================================
# VIEW - User Interface
# ============================================================================

class KaraokeView(tk.Tk):
    """
    The View handles all user interface elements and display.
    
    Responsibilities:
    - Display lyrics and highlight current word
    - Show score and recording status
    - Handle user button clicks
    - Provide feedback through UI updates
    """

    def __init__(self):
        """
        Initialize the tkinter window and create all UI widgets.
        """
        super().__init__()
        self.title("Karaoke App")
        self.geometry("900x700")
        self.controller = None
        
        try:
            self.setup_background()
        except Exception as e:
            print(f"Warning: Could not load background image: {str(e)}")
        
        self.create_widgets()

    def setup_background(self):
        """
        Set background image if available.
        Falls back to plain background if image not found.
        """
        try:
            from PIL import Image, ImageTk
            
            # Try multiple possible background image locations
            bg_paths = [
                SCRIPT_DIR / "Figures1.jpg",
                Path(__file__).parent / "Figures1.jpg",
                Path("Figures1.jpg")
            ]
            
            bg_image = None
            for path in bg_paths:
                if path.exists():
                    img = Image.open(path)
                    img = img.resize((900, 700))
                    self.bg_image = ImageTk.PhotoImage(img)
                    bg_label = tk.Label(self, image=self.bg_image)
                    bg_label.place(relwidth=1, relheight=1)
                    bg_label.lower()  # Send to back
                    return
            
            # If no image found, just use a colored background
            self.configure(bg="#1a1a1a")
            
        except ImportError:
            self.configure(bg="#1a1a1a")

    def create_widgets(self):
        """
        Create and layout all UI elements:
        - Title label
        - Status label
        - Lyrics display with scrollbar
        - Record button
        - Score label
        """
        # Create main frame
        main_frame = tk.Frame(self, bg="rgba(0,0,0,0.8)")
        main_frame.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
        
        # Title
        title_label = tk.Label(
            main_frame,
            text="🎤 Karaoke App - Never Gonna Give You Up 🎤",
            font=("Arial", 20, "bold"),
            bg="black",
            fg="gold"
        )
        title_label.pack(pady=10)
        
        # Status label
        self.status_label = tk.Label(
            main_frame,
            text="Ready to record",
            font=("Arial", 12),
            bg="black",
            fg="white"
        )
        self.status_label.pack(pady=5)
        
        # Lyrics display with scrollbar
        lyrics_frame = tk.Frame(main_frame)
        lyrics_frame.pack(fill=tk.BOTH, expand=True, pady=10)
        
        scrollbar = tk.Scrollbar(lyrics_frame)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
        
        self.lyrics_box = tk.Text(
            lyrics_frame,
            height=15,
            width=80,
            wrap=tk.WORD,
            yscrollcommand=scrollbar.set,
            bg="#2b2b2b",
            fg="white",
            font=("Courier", 11)
        )
        self.lyrics_box.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        scrollbar.config(command=self.lyrics_box.yview)
        
        # Configure text tags for highlighting
        self.lyrics_box.tag_config("current", foreground="yellow", background="blue", font=("Courier", 11, "bold"))
        self.lyrics_box.tag_config("normal", foreground="white")
        
        # Button frame
        button_frame = tk.Frame(main_frame, bg="black")
        button_frame.pack(pady=10)
        
        # Record button
        self.record_btn = tk.Button(
            button_frame,
            text="Start Recording",
            command=self.toggle_recording,
            font=("Arial", 14, "bold"),
            bg="red",
            fg="white",
            padx=20,
            pady=10
        )
        self.record_btn.pack(side=tk.LEFT, padx=10)
        
        # Score label
        self.score_label = tk.Label(
            main_frame,
            text="Score: --",
            font=("Arial", 16, "bold"),
            bg="black",
            fg="lime"
        )
        self.score_label.pack(pady=10)

    def toggle_recording(self):
        """
        Handle record button click - delegate to controller.
        """
        if self.controller:
            self.controller.toggle_recording()

    def update_lyrics(self, text):
        """
        Update the lyrics display with plain text (no highlighting).
        
        Args:
            text (str): The lyrics text to display
        """
        self.lyrics_box.config(state=tk.NORMAL)
        self.lyrics_box.delete("1.0", tk.END)
        self.lyrics_box.insert(tk.END, text, "normal")
        self.lyrics_box.config(state=tk.DISABLED)

    def update_lyrics_with_highlight(self, lyrics_words, current_idx):
        """
        Update lyrics display with highlighting for the current word.
        
        Args:
            lyrics_words (list): List of (word, start_time, end_time) tuples
            current_idx (int): Index of the current word to highlight
        """
        try:
            self.lyrics_box.config(state=tk.NORMAL)
            self.lyrics_box.delete("1.0", tk.END)
            
            for i, (word, _, _) in enumerate(lyrics_words):
                if i == current_idx:
                    self.lyrics_box.insert(tk.END, word + " ", "current")
                else:
                    self.lyrics_box.insert(tk.END, word + " ", "normal")
            
            self.lyrics_box.config(state=tk.DISABLED)
            self.lyrics_box.see(tk.END)  # Auto-scroll to bottom
            
        except Exception as e:
            print(f"Error updating lyrics display: {str(e)}")

    def update_score(self, score):
        """
        Update the displayed score.
        
        Args:
            score (int): The score value to display
        """
        self.score_label.config(text=f"Score: {score}")


# ============================================================================
# MAIN - Application Entry Point
# ============================================================================


if __name__ == "__main__":
    """
    Main entry point for the Karaoke application.
    
    Initializes the Model, View, and Controller in the MVC architecture
    and starts the tkinter event loop.
    """
    try:
        # Create model (loads audio and lyrics)
        print("Loading audio and lyrics...")
        model = KaraokeModel()
        print(f"✓ Loaded song: {SONG_FILE}")
        print(f"✓ Loaded lyrics: {LYRICS_FILE}")
        print(f"✓ Song duration: {model.duration:.1f} seconds")
        
        # Create view (UI)
        view = KaraokeView()
        
        # Create controller (connects Model and View)
        controller = KaraokeController(model, view)
        
        # Start the application
        print("✓ Starting Karaoke application...")
        view.mainloop()
        
    except FileNotFoundError as e:
        print(f"❌ Error: {str(e)}")
        print(f"\nMake sure the following files exist:")
        print(f"  - Song: {SONG_FILE}")
        print(f"  - Lyrics: {LYRICS_FILE}")
    except Exception as e:
        print(f"❌ Fatal error: {str(e)}")
        import traceback
        traceback.print_exc()
