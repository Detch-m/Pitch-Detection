def toggle_recording(model):
        """
        It turns on and off recording. Switches the recording/scoring loop.
        """
        # Volume controls for mixed playback (adjust these values: 0.0 to 1.0)
        song_volume = 0.3  # Reduce song volume (e.g., 0.3 for quieter)
        rec_volume = 1.0   # Recording volume (e.g., 1.0 for full)
        model.fs_song, song = sf.read('Sounds/NeverGonnaGiveYouUp.wav', dtype='float32') # why is dtype float32? It ensures that the audio data is in a consistent format for processing, which is important for accurate pitch detection and scoring.
        if song.ndim > 1:
            song = song[:, 0]  # Convert  to mono if stereo
        song_resampled = sg.resample(song, int(len(song) * model.fs / model.fs_song)) # how does this convert the song to the new sample rate? It uses scipy's resample function, which changes the number of samples in the song according to the ratio of the new sample rate (fs) to the original sample rate (fs_song). The length of the resampled song is calculated as int(len(song) * fs / fs_song), which ensures that the duration of the song remains the same while adjusting for the new sample rate.
        songaudio = song_resampled[:int(duration * model.fs)]  # How  does this Trim to match recording duration? It trims the resampled song to match the duration of the recording by taking only the first int(duration * self.model.fs) samples, which corresponds to the number of samples in the recording duration at the given sample rate (self.model.fs).
        print("Recording for", duration, "seconds... Speak into your microphone while the song plays.")
        # Play the song
        sd.play(songaudio, model.fs)
        duration = len(model.data) / model.fs  # Duration of the song in seconds. Duration = samples / sample_rate 
        recording = sd.rec(int(duration * model.fs), samplerate=model.fs, channels=1) # Start recording audio from the microphone for the duration of the song. The number of samples to record is calculated as int(duration * self.model.fs), which ensures that the recording matches the length of the song. The samplerate is set to self.model.fs, and channels=1 indicates that it will record in mono.
        sd.wait() # Wait until the recording is finished before proceeding. This ensures that the program does not continue to execute until the recording is complete, allowing for proper synchronization between the song playback and the recording process.
        sf.write('Sounds/recorded_audio.wav', recording, model.fs)  # Save recording as WAV file
        print("Recording saved as 'Sounds/recorded_audio.wav'")
        mixed_audio = (rec_volume * recording.flatten() + song_volume * songaudio) / 2  # Apply volumes and average to mix without clipping
        print("Mixed Playback (Recorded + Song) - Adjust volumes in code if needed:")
        ipd.Audio(mixed_audio, rate=model.fs)
        model.recording = True
        model.view.record_btn.config(text="Stop Recording")
